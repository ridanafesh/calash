# Force npm to install devDependencies even when NODE_ENV=production.
#
# Render (and several other Node hosts) set NODE_ENV=production in the
# build environment by default. With that flag, `npm install` skips
# devDependencies — including @types/express, @types/pg, typescript
# itself, etc. — which makes `tsc` fail at build time with errors like:
#
#   Could not find a declaration file for module 'express'
#   Could not find a declaration file for module 'pg'
#   Parameter 'foo' implicitly has an 'any' type.
#
# Setting `production=false` here keeps npm in "include dev deps" mode
# regardless of NODE_ENV, so the build can typecheck. The runtime image
# is still small — devDependencies are used during the build phase only,
# and the deployed `node dist/index.js` doesn't load them.
production=false
