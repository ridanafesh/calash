NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/calash

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS — single allowed origin shared by Express and Socket.IO.
# In production this MUST be set to the deployed frontend URL (e.g.
# https://calash-frontend.onrender.com). The server throws at boot in
# production if neither CLIENT_URL nor CORS_ORIGIN is set.
# CLIENT_URL is the preferred name; CORS_ORIGIN is kept as a legacy alias.
CLIENT_URL=http://localhost:3000
# CORS_ORIGIN=http://localhost:3000

# ── Commerce feature gate ─────────────────────────────────────────────────────
# Set to true to expose /api/commerce/* routes. Requires provider credentials
# below. Keep false until legal review and payment credentials are in place.
COMMERCE_ENABLED=false

# ── Payment providers (all disabled by default) ───────────────────────────────
# PayPal (web_paypal platform)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

# Apple IAP (ios_iap platform)
# APPLE_BUNDLE_ID=
# APPLE_IAP_KEY_ID=
# APPLE_IAP_KEY=
# APPLE_IAP_ISSUER=

# Google Play (android_iap platform)
# GOOGLE_PLAY_PACKAGE_NAME=
# GOOGLE_SERVICE_ACCOUNT_JSON=
